# Copy this file to `apps/android/keystore.properties`
# and fill in your real release signing values.
#
# Do not commit the real `keystore.properties` file.

STORE_FILE=C\:\\path\\to\\release-key.jks
STORE_PASSWORD=replace-with-store-password
KEY_ALIAS=replace-with-key-alias
KEY_PASSWORD=replace-with-key-password
